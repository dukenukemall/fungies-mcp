{
  "name": "@fungiesio/mcp-server",
  "version": "0.2.1",
  "description": "Official Model Context Protocol server for the Fungies Merchant of Record API",
  "keywords": [
    "fungies",
    "mcp",
    "model-context-protocol",
    "merchant-of-record",
    "payments",
    "cursor",
    "claude"
  ],
  "homepage": "https://github.com/dukenukemall/fungies-mcp",
